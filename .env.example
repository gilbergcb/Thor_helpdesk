APP_NAME="THOR-HelpDesk"
ENVIRONMENT=production
API_PREFIX=/api/v1

POSTGRES_DB=helpdesk
POSTGRES_USER=helpdesk
POSTGRES_PASSWORD=troque-esta-senha
POSTGRES_PORT=5432
DATABASE_URL=postgresql+psycopg://helpdesk:troque-esta-senha@db:5432/helpdesk

BACKEND_PORT=8000
FRONTEND_PORT=8080
CORS_ORIGINS=["http://localhost:5173","http://localhost:8080"]
PUBLIC_APP_URL=https://helpdesk.seudominio.com.br

JWT_SECRET_KEY=troque-por-uma-chave-grande-e-aleatoria
# Chave usada para criptografar acessos de clientes. Não perca esta chave.
VAULT_SECRET_KEY=troque-por-outra-chave-grande-e-aleatoria
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=480
SECURITY_PUBLIC_LINK_GUARD=on

# Z-API: use os três campos exibidos no painel/Postman.
# BASE_URL / "API da instância" pode ser apenas https://api.z-api.io ou a URL completa da instância.
ZAPI_BASE_URL=https://api.z-api.io
# INSTANCE_ID / "ID da instância"
ZAPI_INSTANCE_ID=id-da-instancia
# INSTANCE_TOKEN / "Token da instância"
ZAPI_TOKEN=token-da-instancia
# Opcional. Deixe vazio se seu painel não exibir Client-Token/API key separado.
ZAPI_CLIENT_TOKEN=
